# Copy this file to .env and fill in real values:
#   cp .env.example .env

# PostgreSQL (required for Prisma migrate and the API)
# If the password contains @ # : / etc., URL-encode them (e.g. @ -> %40).
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/nine9six?schema=public"

# Solana JSON-RPC (required for on-chain actions)
RPC_URL=""

# AWS S3 (presigned uploads; region is fixed to us-east-1 in code unless you change it)
ACCESS_KEY_ID=""
ACCESS_SECRET=""

# JWT signing (set a strong secret in production)
JWT_SECRET=""

# Treasury Solana address (must match your funded wallet / OWS Solana account)
PARENT_WALLET_ADDRESS=""

# --- Open Wallet Standard (OWS) — https://docs.openwallet.sh ---
# Create platform wallet: ows wallet create --name nine9six-platform
# Solana address must match PARENT_WALLET_ADDRESS (or use env override after creation).
OWS_PLATFORM_WALLET_NAME=""
OWS_WALLET_PASSPHRASE=""
# Optional custom vault (default ~/.ows)
OWS_VAULT_PATH=""

# Optional HTTP gate for sensitive routes (e.g. POST /v1/user/task/:id/approve)
OWS_BACKEND_API_KEY=""

# --- Allium — https://docs.allium.so/api/overview ---
ALLIUM_API_KEY=""
# Optional: API base if different from default
ALLIUM_API_BASE_URL="https://api.allium.so"
# Optional: path for saved Explorer query (enterprise)
ALLIUM_EXPLORER_QUERY_PATH=""
