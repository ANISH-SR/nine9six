# Copy this file to .env and fill in real values:
#   cp .env.example .env

# PostgreSQL (required for Prisma migrate and the API)
# If the password contains @ # : / etc., URL-encode them (e.g. @ -> %40).
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/nine9six?schema=public"

# Solana JSON-RPC (required for on-chain actions)
RPC_URL=""

# AWS S3 (presigned uploads; region is fixed to us-east-1 in code unless you change it)
ACCESS_KEY_ID=""
ACCESS_SECRET=""

# JWT signing (set a strong secret in production)
JWT_SECRET=""
